# Spotify Web API credentials for the /api/spotify serverless function.
# Create an app at https://developer.spotify.com/dashboard to get the ID + secret.
# Copy this file to `.env` for local `vercel dev`, and add the same three vars
# in Vercel → Project → Settings → Environment Variables for production.

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# The id from a PUBLIC playlist's share link:
# https://open.spotify.com/playlist/THIS_PART?si=...
SPOTIFY_PLAYLIST_ID=your_public_playlist_id_here
